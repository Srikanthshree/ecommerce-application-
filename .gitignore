# ── Node / npm ────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Build outputs ─────────────────────────────────────────────────────────────
backend/dist/
frontend/build/

# ── TypeScript cache ──────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Environment / secrets — never commit ─────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── Docker ───────────────────────────────────────────────────────────────────
.dockerignore

# ── OS / editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Local documentation / notes (do not commit) ──────────────────────────────
*.md
